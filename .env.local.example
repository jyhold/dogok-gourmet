# ── 카카오 ─────────────────────────────────────────────
# 카카오 개발자 콘솔 > 앱 > REST API 키 (서버 전용, 절대 프론트 노출 금지)
KAKAO_REST_KEY=

# 카카오맵 JS SDK 키 (프론트 노출 O — 카카오 콘솔에서 배포 도메인 등록 필수)
NEXT_PUBLIC_KAKAO_JS_KEY=

# ── 기상청 (공공데이터포털) ─────────────────────────────
# 단기예보/초단기실황 서비스 키 (서버 전용)
KMA_SERVICE_KEY=

# ── 구글 시트 (관리자DB) ────────────────────────────────
# 시트 ID (URL의 /d/{여기}/ 부분). "링크가 있는 모든 사용자 뷰어"로 공개 필요
GOOGLE_SHEET_ID=
# 탭 이름 (기본: restaurants)
GOOGLE_SHEET_TAB=restaurants

# ── 개발 모드 ───────────────────────────────────────────
# TRUE면 외부 API 대신 mock 데이터 사용 (Phase 1 기본값)
USE_MOCK=TRUE
